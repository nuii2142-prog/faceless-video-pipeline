# Copy this file to ".env" and fill in your own values.
# ".env" is gitignored — NEVER commit real keys.

GEMINI_API_KEY=your-gemini-api-key-here

# Local python paths (adjust to your machine)
PYTHON=C:\Users\you\AppData\Local\Python\bin\python.exe
ML_PYTHON=C:\path\to\project\ml-env\Scripts\python.exe

# ComfyUI (image generation) — defaults shown; override if yours lives elsewhere
COMFY_URL=http://127.0.0.1:8188
COMFY_OUT=C:\path\to\ComfyUI\output
